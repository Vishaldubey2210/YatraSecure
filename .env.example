# YatraSecure - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# Flask Configuration
# ============================================
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-random-string

# ============================================
# Database
# ============================================
# Development (SQLite)
DATABASE_URL=sqlite:///yatra.db

# Production (PostgreSQL - Render/Heroku provides this)
# DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================
# API Keys
# ============================================
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Twitter API (Optional)
TWITTER_BEARER_TOKEN=your-twitter-bearer-token-or-leave-empty

# ============================================
# Map Configuration
# ============================================
MAP_DEFAULT_ZOOM=6
MAP_DEFAULT_CENTER=20.5937,78.9629

# ============================================
# Premium Pricing (in INR)
# ============================================
SINGLE_TRIP_PRICE=99
WEEKEND_TRIP_PRICE=149
LONG_TRIP_PRICE=299
MONTHLY_PRICE=499
ANNUAL_PRICE=2999

# ============================================
# Application Settings
# ============================================
ITEMS_PER_PAGE=12
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif
UPLOAD_FOLDER=static/uploads

# ============================================
# Email Configuration (Optional)
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@yatrasecure.com

# ============================================
# Security
# ============================================
WTF_CSRF_ENABLED=True
SESSION_COOKIE_SECURE=False

# ============================================
# Logging & Debugging
# ============================================
LOG_LEVEL=INFO

# ============================================
# CORS (if using API)
# ============================================
CORS_ORIGINS=*

# ============================================
# Rate Limiting (Optional)
# ============================================
RATELIMIT_ENABLED=False
REDIS_URL=redis://localhost:6379/0
